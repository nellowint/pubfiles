#: templates/registration/account_verification_email.html:1
msgid "Hi"
msgstr "Hola"

#: templates/registration/account_verification_email.html:3
msgid ""
"Click the link below to confirm your email address and activate your account:"
msgstr ""
"Haz clic en el siguiente enlace para confirmar tu correo electrónico y "
"activar tu cuenta:"

#: templates/registration/account_verification_email.html:7
msgid "If you did not create an account, you can ignore this email."
msgstr "Si no creaste una cuenta, ignora este correo."

#: templates/registration/email_verified.html:5
msgid "Email verified"
msgstr "Correo verificado"

#: templates/registration/email_verified.html:15
msgid "Invalid or expired link"
msgstr "Enlace inválido o expirado"

#: templates/registration/email_verified.html:16
msgid ""
"This confirmation link is invalid or has expired. Please try registering "
"again."
msgstr ""
"Este enlace de confirmación es inválido o ha expirado. Intenta registrarte "
"nuevamente."

#: templates/registration/email_verified.html:19
msgid "Register again"
msgstr "Registrarse nuevamente"

#: templates/registration/email_verified.html:23
msgid "Email verified!"
msgstr "¡Correo verificado!"

#: templates/registration/email_verified.html:24
msgid "Your account is now active. You can log in."
msgstr "Tu cuenta está activa. Ya puedes iniciar sesión."

#: templates/registration/email_verified.html:27
#: templates/registration/register.html:47
msgid "Log in"
msgstr "Iniciar sesión"

#: templates/registration/login.html:14
