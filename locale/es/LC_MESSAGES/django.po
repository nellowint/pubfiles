msgid "Updated Password"
msgstr "Contraseña Actualizada"

#: templates/registration/password_reset_complete.html:15
msgid ""
"Your password has been successfully reset! You can now access the platform "
"using your new credentials."
msgstr ""
"¡Tu contraseña ha sido restablecida con éxito! Ya puedes acceder a la "
"plataforma usando tus nuevas credenciales."

