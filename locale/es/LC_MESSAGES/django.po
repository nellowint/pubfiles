"The publication <strong>\"%(title)s\"</strong> requires an active "
"subscription to read from this page."
msgstr ""
"La publicación <strong>\"%(title)s\"</strong> requiere una suscripción "
"activa para leer desde esta página."

#: templates/publications/premium.html:22
#, python-format
msgid "Premium subscription: <strong>%(currency)s %(price)s</strong> / month."
msgstr "Suscripción Premium: <strong>%(currency)s %(price)s</strong> / mes."

#: templates/publications/premium.html:28
msgid ""
"Create your account or log in now and subscribe to unlock unlimited access "
"to our entire catalog of magazines and comics."
msgstr ""
"Crea tu cuenta o inicia sesión ahora y suscríbete para desbloquear acceso "
"ilimitado a todo nuestro catálogo de revistas y cómics."

#: templates/publications/premium.html:34
#, python-format
msgid ""
"Hi <strong>%(email)s</strong>, your account does not have an active "
"subscription yet. Subscribe to Premium to unlock this page and the rest of "
"<strong>\"%(title)s\"</strong>."
msgstr ""
"Hola <strong>%(email)s</strong>, tu cuenta aún no tiene una suscripción "
"activa. Suscríbete a Premium para desbloquear esta página y el resto de "
"<strong>\"%(title)s\"</strong>."

