#: templates/publications/premium.html:5
msgid "Restricted Content"
msgstr "Conteúdo Restrito"

#: templates/publications/premium.html:16
msgid "This page is exclusive to Subscribers"
msgstr "Esta página é exclusiva para Assinantes"

#: templates/publications/premium.html:18
#, python-format
msgid ""
"The publication <strong>\"%(title)s\"</strong> requires an active "
"subscription to read from this page."
msgstr ""
"A publicação <strong>\"%(title)s\"</strong> requer uma assinatura ativa para "
"ler a partir desta página."

#: templates/publications/premium.html:22
#, python-format
msgid "Premium subscription: <strong>%(currency)s %(price)s</strong> / month."
msgstr "Assinatura Premium: <strong>%(currency)s %(price)s</strong> / mês."

#: templates/publications/premium.html:28
msgid ""
"Create your account or log in now and subscribe to unlock unlimited access "
"to our entire catalog of magazines and comics."
msgstr ""
"Crie sua conta ou faça login agora e assine para desbloquear acesso "
"ilimitado a todo o nosso catálogo de revistas e quadrinhos."

#: templates/publications/premium.html:34
#, python-format
msgid ""
"Hi <strong>%(email)s</strong>, your account does not have an active "
"subscription yet. Subscribe to Premium to unlock this page and the rest of "
"<strong>\"%(title)s\"</strong>."
msgstr ""
"Olá <strong>%(email)s</strong>, sua conta ainda não possui uma assinatura "
"ativa. Assine o Premium para desbloquear esta página e o restante de "
"<strong>\"%(title)s\"</strong>."

#: templates/publications/premium.html:37
msgid "Activate Subscription"
msgstr "Ativar Assinatura"

#: templates/publications/premium.html:43
msgid "Back to publication details"
msgstr "Voltar aos detalhes da publicação"

